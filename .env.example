# OpenAI Codex OAuth via ChatGPT Plus / Pro
#
# 1. Install deps with uv:
#    uv sync
#
# 2. Login once:
#    uv run python agents/login_openai_codex.py
#
# 3. Run any agent script:
#    uv run python agents/s01_agent_loop.py

# Model ID (required)
MODEL_ID=gpt-5.1-codex

# Optional: override the Codex endpoint.
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex/responses

# Optional: tag requests with a custom originator string.
# OPENAI_CODEX_ORIGINATOR=learn-claude-code

# Optional: disable auto-starting interactive OAuth during the first model call.
# OPENAI_CODEX_AUTO_LOGIN=1

# Optional: retry with insecure SSL when your local cert store is broken.
# OPENAI_CODEX_VERIFY_SSL=1
